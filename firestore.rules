rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      // Relaxing for now to ensure connectivity; verify in production
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        getUserData().role == 'superadmin' || 
        request.auth.token.email == 'lutheranchurch.priangaol@gmail.com'
      );
    }

    function isStaff() {
      return isSignedIn() && (
        getUserData().role == 'staff' || 
        isSuperAdmin()
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---
    function isValidChurch(data) {
      return data.nama is string && data.nama.size() <= 200 &&
             data.resort is string && data.resort.size() <= 200;
    }

    function isValidPayment(data) {
      return data.gerejaId is string &&
             data.kategori in ['laporan', 'pelean', 'alaman'] &&
             data.periode is string &&
             data.jumlah is number && data.jumlah >= 0;
    }

    function isValidDistribution(data) {
      return data.gerejaId is string &&
             data.periode is string &&
             data.details is map &&
             data.tanggal is string;
    }

    // --- Match Rules ---

    // Allow connection testing
    match /test/connection {
      allow read: if true;
    }

    // Churches
    match /churches/{churchId} {
      allow read: if true;
      allow create: if isSuperAdmin() && isValidChurch(incoming()) && isValidId(churchId);
      allow update: if isSuperAdmin() && isValidChurch(incoming());
      allow delete: if isSuperAdmin();
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() && isValidPayment(incoming()) && 
                    exists(/databases/$(database)/documents/churches/$(incoming().gerejaId));
      allow update: if isSuperAdmin() && isValidPayment(incoming());
      allow delete: if isSuperAdmin();
    }

    // Distributions
    match /distributions/{distId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin() && isValidDistribution(incoming()) && 
                    exists(/databases/$(database)/documents/churches/$(incoming().gerejaId));
      allow update: if isSuperAdmin() && isValidDistribution(incoming());
      allow delete: if isSuperAdmin();
    }

    // Settings
    match /settings/config {
      allow read: if true; // Public view for branding
      allow write: if isSuperAdmin();
    }

    // User Roles
    match /users/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null && request.auth.uid == userId; 
      allow update: if isSuperAdmin(); // Only admin can promote
      allow delete: if isSuperAdmin();
    }
  }
}
