rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'lutheranchurch.priangaol@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin')
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 256 && id.matches('^[a-zA-Z0-9_\\-\\.\\s]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---
    function isValidChurch(data) {
      return data.nama is string && data.nama.size() <= 500 &&
             data.resort is string && data.resort.size() <= 500;
    }

    function isValidPayment(data) {
      return data.gerejaId is string &&
             data.kategori in ['laporan', 'pelean', 'alaman'] &&
             data.periode is string;
    }

    function isValidDistribution(data) {
      return data.gerejaId is string &&
             data.periode is string;
    }

    function isVirtualId(id) {
      return id.startsWith('virtual_') || id.startsWith('v-h-') || id.startsWith('v-dist-');
    }

    // --- Match Rules ---

    // Allow connection testing
    match /test/connection {
      allow read: if true;
    }

    // Churches
    match /churches/{churchId} {
      allow read: if true;
      allow create: if isSuperAdmin() && isValidChurch(incoming()) && isValidId(churchId);
      allow update: if isSuperAdmin() && isValidChurch(incoming());
      allow delete: if isSuperAdmin();
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create: if isStaff() && isValidPayment(incoming()) && 
                    (isVirtualId(incoming().gerejaId) || exists(/databases/$(database)/documents/churches/$(incoming().gerejaId)));
      allow update: if isStaff() && isValidPayment(incoming());
      allow delete: if isSuperAdmin();
    }

    // Distributions
    match /distributions/{distId} {
      allow read: if isSignedIn();
      allow create: if isStaff() && isValidDistribution(incoming()) && 
                    (isVirtualId(incoming().gerejaId) || exists(/databases/$(database)/documents/churches/$(incoming().gerejaId)));
      allow update: if isStaff() && isValidDistribution(incoming());
      allow delete: if isSuperAdmin();
    }

    // Settings
    match /settings/config {
      allow read: if true; // Public view for branding
      allow write: if isSuperAdmin();
    }

    // User Roles
    match /users/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null && request.auth.uid == userId; 
      allow update: if isSuperAdmin(); // Only admin can promote
      allow delete: if isSuperAdmin();
    }
  }
}
